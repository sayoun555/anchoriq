{
  "_about": "Codex CLI 훅 어댑터. 타깃 repo의 .codex/hooks.json 으로 복사(또는 병합). matcher=apply_patch(Codex 에디터 툴). 경로는 설치 위치에 맞게 install.sh가 조정하거나 직접 수정. 근거: docs/harness-engineering/research/CODEX_AND_PORTABILITY.md",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/session-context.sh",
            "timeout": 15,
            "statusMessage": "하네스 연속성(progress)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/adapters/codex/codex-hook.sh post",
            "timeout": 60,
            "statusMessage": "하네스 결정론 게이트(check)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .harness/adapters/codex/codex-hook.sh stop",
            "timeout": 300,
            "statusMessage": "하네스 전체 검사 + 의미 적대자(review)"
          }
        ]
      }
    ]
  }
}
