{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "JVM Heap Memory (Used vs Max)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 20 }
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", application=\"anchoriq\"}",
          "legendFormat": "Used ({{id}})",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\", application=\"anchoriq\"}",
          "legendFormat": "Max ({{id}})",
          "refId": "B"
        }
      ]
    },
    {
      "title": "GC Count & Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{application=\"anchoriq\"}[5m])",
          "legendFormat": "GC Count/s ({{cause}})",
          "refId": "A"
        },
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"anchoriq\"}[5m])",
          "legendFormat": "GC Time/s ({{cause}})",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Active Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"anchoriq\"}",
          "legendFormat": "Live Threads",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"anchoriq\"}",
          "legendFormat": "Daemon Threads",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"anchoriq\"}",
          "legendFormat": "Peak Threads",
          "refId": "C"
        }
      ]
    },
    {
      "title": "HTTP Requests / Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"anchoriq\"}[5m])",
          "legendFormat": "Total Requests/s ({{status}})",
          "refId": "A"
        },
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"anchoriq\", status=~\"5..\"}[5m])",
          "legendFormat": "5xx Errors/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "API Response Time (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{application=\"anchoriq\"}[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"anchoriq\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"anchoriq\"}[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["anchoriq", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AnchorIQ - System Overview",
  "uid": "anchoriq-overview",
  "version": 1
}
